# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/trainer_platform

# Supabase (Alternative to Railway PostgreSQL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe (Payment)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Kaspi (Payment - Kazakhstan)
KASPI_API_KEY=your_kaspi_api_key
KASPI_MERCHANT_ID=your_merchant_id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Email
SENDGRID_API_KEY=your_sendgrid_key
SENDER_EMAIL=noreply@trainerhub.kz

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars_long
